{
  "routes": [
    {
      "src": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "www.systemmanager.com.br"
        }
      ],
      "status": 308,
      "headers": {
        "Location": "https://systemmanager.com.br/$1"
      }
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/passoapassodigital/(.*)",
      "dest": "https://mail.systemmanager.com.br/passoapassodigital/$1"
    },
    {
      "src": "/passoapassodigital",
      "dest": "https://mail.systemmanager.com.br/passoapassodigital/"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
